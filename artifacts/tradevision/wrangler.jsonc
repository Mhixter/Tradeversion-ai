{
  // Cloudflare Worker configuration for the Tradevision frontend
  "name": "tradeversion-ai",
  "compatibility_date": "2024-09-23",
  "assets": {
    // Vite builds into dist/public (see vite.config.ts build.outDir)
    "directory": "./dist/public",
    "html_handling": "auto-trailing-slash",
    // Serve index.html for all unmatched routes (SPA routing via Wouter)
    "not_found_handling": "single-page-application"
  }
}
